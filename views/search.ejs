<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Search — FilmPedia</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>

  <%- include('header', { currentPageNav: 'search', query: query }) %>

  <main>
    <section class="section-band">
      <div class="container">
        <h1 style="margin-bottom:var(--space-sm);">🔍 Hasil Pencarian</h1>
        
        <% if (query) { %>
          <p class="search-query">
            Menampilkan hasil untuk: "<strong><%= query %></strong>"
          </p>
        <% } %>

        <% if (movies.length === 0 && query) { %>
          <div class="empty-state">
            <div class="icon">😕</div>
            <h3>Tidak ada film ditemukan</h3>
            <p>Coba dengan kata kunci lain.</p>
          </div>
        <% } else if (!query) { %>
          <div class="empty-state">
            <div class="icon">🔎</div>
            <h3>Cari film favoritmu</h3>
            <p>Ketik judul film di atas.</p>
          </div>
        <% } else { %>
          <div class="movie-grid">
            <% movies.forEach(movie => { %>
              <a href="/movie/<%= movie.id %>" class="movie-card">
                <img src="https://image.tmdb.org/t/p/w500<%= movie.poster_path %>" 
                     alt="<%= movie.original_title %>" onerror="this.src='/placeholder.jpg'">
                <div class="movie-card-info">
                  <h3><%= movie.original_title %></h3>
                  <div class="meta">
                    <span class="rating">⭐ <%= movie.vote_average?.toFixed(1) || 'N/A' %></span>
                    <span><%= movie.release_date?.slice(0,4) || 'TBA' %></span>
                  </div>
                  <div class="genre-chips">
                    <span class="chip">Action</span>
                    <span class="chip">Drama</span>
                  </div>
                </div>
              </a>
            <% }) %>
          </div>
        <% } %>
      </div>
    </section>
  </main>

  <%- include('footer') %>

</body>
</html>