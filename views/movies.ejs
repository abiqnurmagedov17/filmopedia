<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — FilmPedia</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>

  <header class="site-header">
    <div class="container">
      <a href="/" class="logo">Film<span>Pedia</span></a>
      <nav class="nav-links" id="navLinks">
        <a href="/movies/trending">Trending</a>
        <a href="/movies/popular">Popular</a>
        <a href="/movies/top">Top Rated</a>
        <a href="/movies/upcoming">Upcoming</a>
        <a href="/movies/now-playing">Now Playing</a>
        <a href="/movies/discover">Discover</a>
      </nav>
      <div class="nav-actions">
        <form action="/search" class="search-form">
          <input type="text" name="q" placeholder="Cari film...">
          <button type="submit">Cari</button>
        </form>
        <button class="hamburger" id="hamburger">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>
  </header>

  <main>
    <section class="section-band">
      <div class="container">
        <div class="section-header">
          <h1><%= title %></h1>
          <% if (window === 'week' || window === 'day') { %>
            <div style="display:flex;gap:8px;">
              <a href="/movies/trending?window=day" class="btn-secondary" style="<%= window === 'day' ? 'background:var(--primary);color:var(--on-primary);' : '' %>">
                Hari Ini
              </a>
              <a href="/movies/trending?window=week" class="btn-secondary" style="<%= window === 'week' ? 'background:var(--primary);color:var(--on-primary);' : '' %>">
                Minggu Ini
              </a>
            </div>
          <% } %>
        </div>

        <div class="movie-grid">
          <% movies.forEach(movie => { %>
            <a href="/movie/<%= movie.id %>" class="movie-card">
              <img src="https://image.tmdb.org/t/p/w500<%= movie.poster_path %>" 
                   alt="<%= movie.original_title %>" onerror="this.src='/placeholder.jpg'">
              <div class="movie-card-info">
                <h3><%= movie.original_title %></h3>
                <div class="meta">
                  <span class="rating">⭐ <%= movie.vote_average?.toFixed(1) || 'N/A' %></span>
                  <span><%= movie.release_date?.slice(0,4) || 'TBA' %></span>
                </div>
              </div>
            </a>
          <% }) %>
        </div>

        <% if (totalPages > 1) { %>
          <div class="pagination">
            <% 
              const maxPages = Math.min(totalPages, 10);
              for (let i = 1; i <= maxPages; i++) { 
                const isActive = i === currentPage;
                let url = basePath + '?page=' + i;
                if (window === 'day' || window === 'week') {
                  url += '&window=' + window;
                }
            %>
              <a href="<%= url %>" class="<%= isActive ? 'active' : '' %>">
                <%= i %>
              </a>
            <% } %>
          </div>
        <% } %>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-brand">
          <a href="/" class="logo">Film<span>Pedia</span></a>
          <p>Discover movies, explore genres, and find your next favorite film.</p>
        </div>
        <div>
          <h4>Kategori</h4>
          <a href="/movies/trending">Trending</a>
          <a href="/movies/popular">Popular</a>
          <a href="/movies/top">Top Rated</a>
          <a href="/movies/upcoming">Upcoming</a>
        </div>
        <div>
          <h4>Lainnya</h4>
          <a href="/search">Cari</a>
          <a href="/movies/discover">Discover</a>
        </div>
        <div>
          <h4>Tentang</h4>
          <a href="#">Ditenagai TMDB</a>
        </div>
      </div>
      <div class="footer-bottom">
        <span>© 2026 FilmPedia</span>
        <span>Data dari TMDB</span>
      </div>
    </div>
  </footer>

  <script>
    document.getElementById('hamburger')?.addEventListener('click', function() {
      document.getElementById('navLinks')?.classList.toggle('open');
    });
  </script>

</body>
</html>