<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= movie.title %> — FilmPedia</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>

  <%- include('header', { currentPageNav: 'movie' }) %>

  <main class="container movie-detail">
    <div class="detail-layout">
      <div class="detail-poster">
        <img src="https://image.tmdb.org/t/p/w500<%= movie.poster_path %>" 
             alt="<%= movie.title %>" onerror="this.src='/placeholder.jpg'">
      </div>

      <div class="detail-content">
        <h1><%= movie.title %></h1>
        <% if (movie.tagline) { %>
          <p class="tagline">“<%= movie.tagline %>”</p>
        <% } %>

        <div class="detail-meta">
          <span class="rating">⭐ <%= movie.vote_average?.toFixed(1) || 'N/A' %></span>
          <span>📅 <%= movie.release_date || 'TBA' %></span>
          <span>⏱️ <%= movie.runtime || '?' %> min</span>
          <span>🗣️ <%= movie.original_language?.toUpperCase() || 'N/A' %></span>
        </div>

        <p class="overview"><%= movie.overview %></p>

        <% if (movie.genres?.length) { %>
          <div class="genre-tags">
            <% movie.genres.forEach(g => { %>
              <span class="genre-tag"><%= g.name %></span>
            <% }) %>
          </div>
        <% } %>

        <!-- Cast -->
        <% if (credits.cast.length) { %>
          <h3 style="font-family:var(--font-display);font-weight:400;margin:var(--space-lg) 0 var(--space-md);">
            Pemeran
          </h3>
          <div class="cast-grid">
            <% credits.cast.slice(0, 10).forEach(c => { %>
              <div class="cast-item">
                <img src="https://image.tmdb.org/t/p/w185<%= c.profile_path %>" 
                     alt="<%= c.name %>" onerror="this.src='/placeholder.jpg'">
                <div class="name"><%= c.name %></div>
                <div class="character"><%= c.character %></div>
              </div>
            <% }) %>
          </div>
        <% } %>

        <!-- Trailers -->
        <% if (videos.length) { %>
          <h3 style="font-family:var(--font-display);font-weight:400;margin:var(--space-lg) 0 var(--space-md);">
            🎬 Trailer
          </h3>
          <div class="trailer-grid">
            <% videos.slice(0, 4).forEach(v => { %>
              <iframe src="https://m.youtube.com/embed/<%= v.key %>" 
                      allowfullscreen></iframe>
            <% }) %>
          </div>
        <% } %>

        <!-- Similar -->
        <% if (similar.length) { %>
          <h3 style="font-family:var(--font-display);font-weight:400;margin:var(--space-lg) 0 var(--space-md);">
            Film Serupa
          </h3>
          <div class="movie-reel">
            <% similar.slice(0, 8).forEach(m => { %>
              <a href="/movie/<%= m.id %>" class="movie-card">
                <img src="https://image.tmdb.org/t/p/w185<%= m.poster_path %>" 
                     alt="<%= m.original_title %>" onerror="this.src='/placeholder.jpg'">
                <div class="movie-card-info">
                  <h3><%= m.original_title %></h3>
                  <div class="meta">
                    <span class="rating">⭐ <%= m.vote_average?.toFixed(1) || 'N/A' %></span>
                  </div>
                </div>
              </a>
            <% }) %>
          </div>
        <% } %>

        <!-- Recommendations -->
        <% if (recommendations.length) { %>
          <h3 style="font-family:var(--font-display);font-weight:400;margin:var(--space-lg) 0 var(--space-md);">
            💡 Rekomendasi
          </h3>
          <div class="movie-reel">
            <% recommendations.slice(0, 8).forEach(m => { %>
              <a href="/movie/<%= m.id %>" class="movie-card">
                <img src="https://image.tmdb.org/t/p/w185<%= m.poster_path %>" 
                     alt="<%= m.original_title %>" onerror="this.src='/placeholder.jpg'">
                <div class="movie-card-info">
                  <h3><%= m.original_title %></h3>
                  <div class="meta">
                    <span class="rating">⭐ <%= m.vote_average?.toFixed(1) || 'N/A' %></span>
                  </div>
                </div>
              </a>
            <% }) %>
          </div>
        <% } %>
      </div>
    </div>
  </main>

  <%- include('footer') %>

</body>
</html>