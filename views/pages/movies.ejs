<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — FilmPedia</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>

  <%- include('../partials/header.ejs', { currentPage: title.toLowerCase().replace(' ', '-') }) %>

  <main>
    <section class="section-band">
      <div class="container">
        <div class="section-header">
          <h1><%= title %></h1>
          <% if (typeof window !== 'undefined') { %>
            <div style="display:flex;gap:var(--space-xs);">
              <a href="/movies/trending?window=day" class="btn-tab <%= window === 'day' ? 'btn-tab-active' : 'btn-tab-inactive' %>">
                Hari Ini
              </a>
              <a href="/movies/trending?window=week" class="btn-tab <%= window === 'week' ? 'btn-tab-active' : 'btn-tab-inactive' %>">
                Minggu Ini
              </a>
            </div>
          <% } %>
        </div>

        <!-- SKELETON LOADING (contoh) -->
        <% if (typeof isLoading !== 'undefined' && isLoading) { %>
          <div class="movie-grid-skeleton">
            <% for (let i = 0; i < 8; i++) { %>
              <div class="movie-card-skeleton">
                <div class="skeleton-poster"></div>
                <div class="skeleton-title"></div>
                <div class="skeleton-meta"></div>
              </div>
            <% } %>
          </div>
        <% } else { %>
          <div class="movie-grid">
            <% movies.forEach((movie, index) => { %>
              <a href="/movie/<%= movie.id %>" class="movie-card">
                <% if (index === 0 && title === 'Trending') { %>
                  <span class="badge badge-trending">🔥 Trending</span>
                <% } else if (index === 0 && title === 'Now Playing') { %>
                  <span class="badge badge-new">Baru</span>
                <% } else if (index < 2 && title === 'Top Rated') { %>
                  <span class="badge badge-hot">⭐ Best</span>
                <% } %>
                <img src="https://image.tmdb.org/t/p/w500<%= movie.poster_path %>" 
                     alt="<%= movie.original_title %>" onerror="this.src='/placeholder.jpg'">
                <div class="movie-card-info">
                  <h3><%= movie.original_title %></h3>
                  <div class="meta">
                    <span class="rating">⭐ <%= movie.vote_average?.toFixed(1) || 'N/A' %></span>
                    <span><%= movie.release_date?.slice(0,4) || 'TBA' %></span>
                    <span><%= movie.runtime || '?' %>m</span>
                  </div>
                  <div class="genre-chips">
                    <span class="chip">Action</span>
                    <span class="chip">Drama</span>
                  </div>
                </div>
                <div class="card-hover-overlay">
                  <p><%= movie.overview?.slice(0, 100) %>...</p>
                </div>
              </a>
            <% }) %>
          </div>
        <% } %>

        <% if (movies.length === 0 && !isLoading) { %>
          <div class="empty-state">
            <div class="icon">😕</div>
            <h3>Tidak ada film ditemukan</h3>
          </div>
        <% } %>

        <% if (totalPages > 1) { %>
          <div class="pagination">
            <% 
              const maxPages = Math.min(totalPages, 10);
              for (let i = 1; i <= maxPages; i++) { 
                const isActive = i === currentPage;
                let url = basePath + '?page=' + i;
                if (typeof window !== 'undefined' && (window === 'day' || window === 'week')) {
                  url += '&window=' + window;
                }
            %>
              <a href="<%= url %>" class="<%= isActive ? 'active' : '' %>">
                <%= i %>
              </a>
            <% } %>
          </div>
        <% } %>
      </div>
    </section>
  </main>

  <%- include('../partials/footer.ejs') %>

</body>
</html>